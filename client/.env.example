# Rename this file to .env before running the client locally.
# On Vercel, add these same keys under Project Settings -> Environment Variables instead.
# Vite only exposes variables that start with VITE_ to the browser.

# The base URL of your deployed backend API (no trailing slash)
# Local example: http://localhost:5000/api
# Production example: https://tripify-server.onrender.com/api
VITE_API_BASE_URL=http://localhost:5000/api

# Your Google Maps API key, with "Maps JavaScript API" and "Directions API" enabled
# Get one at: https://console.cloud.google.com/google/maps-apis
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
