# Rename this file to .env for local development.
# On Vercel, add these under Project Settings → Environment Variables.

# Base URL of your backend API (no trailing slash)
VITE_API_BASE_URL=http://localhost:5000/api

# Free OpenRouteService key for geocoding and road routes
# Sign up at: https://openrouteservice.org/dev/#/signup
VITE_ORS_API_KEY=your_openrouteservice_key_here

# Gemini 1.5 Flash key for the AI itinerary feature
# Get one free at: https://aistudio.google.com/app/apikey
# Enable "Generative Language API" in your Google Cloud project
VITE_GEMINI_API_KEY=your_gemini_api_key_here
