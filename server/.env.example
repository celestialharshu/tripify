# Rename this file to .env before running the server locally.
# On Render, add these same keys under your service's Environment tab instead of uploading a .env file.

# Port the Express server will run on (Render sets this automatically, 5000 is for local dev)
PORT=5000

# Your MongoDB connection string (MongoDB Atlas recommended)
# Example: mongodb+srv://username:password@cluster.mongodb.net/tripify
MONGO_URI=your_mongodb_connection_string_here

# Any long random string, used to sign login tokens
JWT_SECRET=replace_this_with_a_long_random_string

# The deployed URL of your client app, used so the server only accepts requests from it
# Example: https://tripify.vercel.app
CLIENT_URL=http://localhost:5173
